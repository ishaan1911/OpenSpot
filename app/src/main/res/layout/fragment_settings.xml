<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvGeofenceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geofence Detection"
        android:textSize="16sp"
        android:textColor="#1A1A1A"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/switchGeofence"
        android:layout_marginTop="32dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchGeofence"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvGeofenceDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Automatically update lot status when you enter or exit a parking area"
        android:textSize="13sp"
        android:textColor="#999999"
        app:layout_constraintTop_toBottomOf="@id/tvGeofenceLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/tvGeofenceDesc"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvNotificationsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lot Status Notifications"
        android:textSize="16sp"
        android:textColor="#1A1A1A"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/switchNotifications"
        android:layout_marginTop="24dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchNotifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvNotificationsDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Get notified when your preferred lot status changes"
        android:textSize="13sp"
        android:textColor="#999999"
        app:layout_constraintTop_toBottomOf="@id/tvNotificationsLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/tvNotificationsDesc"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OpenSpot v1.0 — WPI CS 528"
        android:textSize="13sp"
        android:textColor="#BBBBBB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
