<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:paddingTop="12dp"
    android:paddingBottom="32dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- Drag handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#DDDDDD"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Status dot + lot name -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:background="@drawable/circle_indicator"
        app:layout_constraintTop_toBottomOf="@id/dragHandle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvLotName"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tvLotName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/dragHandle"
        app:layout_constraintStart_toEndOf="@id/statusDot"
        app:layout_constraintEnd_toStartOf="@id/tvStatusBadge"/>

    <TextView
        android:id="@+id/tvStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textStyle="bold"
        android:padding="6dp"
        android:background="@drawable/status_badge"
        app:layout_constraintTop_toTopOf="@id/tvLotName"
        app:layout_constraintBottom_toBottomOf="@id/tvLotName"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Occupancy progress -->
    <TextView
        android:id="@+id/tvOccupancy"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvLotName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/tvOccupancyCount"/>

    <TextView
        android:id="@+id/tvOccupancyCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvLotName"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ProgressBar
        android:id="@+id/occupancyProgress"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:progressTint="#4CAF50"
        android:progressBackgroundTint="#EEEEEE"
        android:max="100"
        android:progress="0"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvOccupancy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Permit types -->
    <TextView
        android:id="@+id/tvPermitLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Permitted"
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/occupancyProgress"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvPermitTypes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#1A1A1A"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvPermitLabel"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Last updated -->
    <TextView
        android:id="@+id/tvLastUpdated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#BBBBBB"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvPermitTypes"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Directions buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDirections"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Get Directions"
        android:textSize="15sp"
        android:backgroundTint="#1565C0"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLastUpdated"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnGoogleMaps"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleMaps"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Google Maps"
        android:textSize="15sp"
        android:textColor="#1565C0"
        app:strokeColor="#1565C0"
        app:strokeWidth="1dp"
        android:backgroundTint="@android:color/white"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLastUpdated"
        app:layout_constraintStart_toEndOf="@id/btnDirections"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
